PORT=3007

# Supabase — ver docs/SUPABASE_LOCAL.md
# Opción A (nube): Project Settings → API → Project URL + Secret key (service_role)
# Opción B (Docker): supabase start → supabase status
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# No usada por el backend actualmente (solo service_role)
SUPABASE_ANON_KEY=

# Integración G5 — Pedidos (Render)
G5_ORDER_SERVICE_URL=https://pedidos-g5.onrender.com
G9_NOTIFICATION_SERVICE_URL=http://localhost:3008

# RabbitMQ G8 — broker público CloudAMQP (ver docs/RABBITMQ_G8.md)
# Copiar AMQP URL desde CloudAMQP → instancia → Details → AMQP URL (botón Copy)
# Usuario/vhost suele ser trdnumkd en jackal.rmq.cloudamqp.com
RABBITMQ_URL=amqps://trdnumkd:zG2qJNysAXbBzz70LtdSMetY4P_yo4Rw@jackal.rmq.cloudamqp.com/trdnumkd
RABBITMQ_EXCHANGE=fishmarket.events