meta {
  name: 01 Health check
  type: http
  seq: 1
}

get {
  url: {{base_url}}/health
  body: none
  auth: none
}

headers {
  X-Correlation-Id: {{$randomUUID}}
  X-Consumer: dispatch-service
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("persistencia supabase o memory", function() {
    expect(res.body.persistence).to.be.oneOf(["supabase", "memory"]);
  });
}
