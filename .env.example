PORT=3007

# Supabase — ver docs/SUPABASE_LOCAL.md
# Opción A (nube): Project Settings → API → Project URL + Secret key (service_role)
# Opción B (Docker): supabase start → supabase status
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# No usada por el backend actualmente (solo service_role)
SUPABASE_ANON_KEY=

# Integraciones mock / REST (E4 híbrido)
G5_ORDER_SERVICE_URL=http://localhost:3004
G9_NOTIFICATION_SERVICE_URL=http://localhost:3008
G9_NOTIFY_VIA_REST=true

# RabbitMQ — ver docs/integracion/RABBITMQ.md
RABBITMQ_URL=
RABBITMQ_EXCHANGE=fishmarket.events
RABBITMQ_ORDER_QUEUE=g8.dispatch.orders
RABBITMQ_ORDER_ROUTING_KEYS=ReadyToShip,OrderReadyToShip,order.ready_to_ship