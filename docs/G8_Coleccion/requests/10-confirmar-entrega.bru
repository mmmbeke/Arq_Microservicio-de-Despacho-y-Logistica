meta {
  name: 10 Confirmar entrega
  type: http
  seq: 10
}

post {
  url: {{base_url}}/v1/shipments/shp_gqufnow2/confirm
  body: none
  auth: none
}

headers {
  X-Correlation-Id: corr-test-001
  X-Consumer: g8-despacho
  Idempotency-Key: idem-confirm-001
  If-Match: {{etagConfirm}}
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("estado DELIVERED", function() {
    expect(res.body.status).to.equal("DELIVERED");
  });
}
