meta {
  name: 10 Confirmar entrega
  type: http
  seq: 10
}

post {
  url: {{base_url}}/v1/shipments/shp_a1b2c3/confirm
}

headers {
  X-Correlation-Id: {{$randomUUID}}
  X-Consumer: dispatch-service
  Idempotency-Key: {{$randomUUID}}
  If-Match: {{etagConfirm}}
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("estado DELIVERED", function() {
    expect(res.body.status).to.equal("DELIVERED");
  });
}
